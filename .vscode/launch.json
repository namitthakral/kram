    "version": "0.2.0",
    "configurations": [
        {
            "name": "Ed-Verse (Local - Web)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--dart-define=BASE_URL=http://192.168.1.11:3001",
                "-d",
                "chrome",
                "--web-port",
                "7000",
                "--web-hostname",
                "127.0.0.1"
            ]
        },
        {
            "name": "Ed-Verse (Local - App)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=BASE_URL=http://192.168.1.11:3001"
            ]
        },
        {
            "name": "Ed-Verse (Production - Web)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--dart-define=BASE_URL=https://api.kramedu.in",
                "-d",
                "chrome",
                "--web-port",
                "7000",
                "--web-hostname",
                "127.0.0.1"
            ]
        },
        {
            "name": "Ed-Verse (Production - App)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=BASE_URL=https://api.kramedu.in"
            ]
        },
