    "version": "0.2.0",
    "configurations": [
        {
            "name": "Kram (Local - Web)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--dart-define=BASE_URL=http://localhost:3000",
                "-d",
                "chrome",
                "--web-port",
                "7000",
                "--web-hostname",
                "127.0.0.1"
            ]
        },
        {
            "name": "Kram (Local - App)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=BASE_URL=http://localhost:3000"
            ]
        },
        {
            "name": "Kram (Production - Web)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--dart-define=BASE_URL=https://api.kramedu.in",
                "-d",
                "chrome",
                "--web-port",
                "7000",
                "--web-hostname",
                "127.0.0.1"
            ]
        },
        {
            "name": "Kram (Production - App)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=BASE_URL=https://api.kramedu.in"
            ]
        },
