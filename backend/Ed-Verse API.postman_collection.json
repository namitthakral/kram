					"name": "User Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.accessToken) {",
									"        pm.environment.set('token', response.accessToken);",
									"        console.log('Token saved:', response.accessToken);",
									"    }",
