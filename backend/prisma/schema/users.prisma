// ============================================================================
// STUDENT AND TEACHER MODELS
// ============================================================================

model Student {
  id                    Int              @id @default(autoincrement())
  userId                Int              @unique @map("user_id")
  institutionId         Int              @map("institution_id")

  // Legacy fields - will be removed in migration
  courseId              Int?             @map("course_id") // Legacy - will be removed
  classDivisionId       Int?             @map("class_division_id") // Legacy - will be removed
  rollNumber            String?          @map("roll_number") @db.VarChar(50) // Legacy - will be removed
  currentSemester       Int?             @map("current_semester") // Legacy - will be removed
  currentYear           Int?             @map("current_year") // Legacy - will be removed
  section               String?          @db.VarChar(10) // Legacy - will be removed

  // Permanent student information
  admissionNumber       String           @unique @map("admission_number") @db.VarChar(50)
  admissionDate         DateTime?        @map("admission_date") @db.Date
  graduationDate        DateTime?        @map("graduation_date") @db.Date
  studentType           StudentType      @default(REGULAR) @map("student_type")
  residentialStatus     ResidentialStatus @default(DAY_SCHOLAR) @map("residential_status")
  transportRequired     Boolean          @default(false) @map("transport_required")

  // Board examination roll numbers (permanent)
  class10BoardRollNo    String?          @map("class10_board_roll_no") @db.VarChar(50)
  class12BoardRollNo    String?          @map("class12_board_roll_no") @db.VarChar(50)
  collegeRollNumber     String?          @map("college_roll_number") @db.VarChar(50)

  // Personal information
  emergencyContactName  String?          @map("emergency_contact_name") @db.VarChar(100)
  emergencyContactPhone String?          @map("emergency_contact_phone") @db.VarChar(15)
  emergencyContactEmail String?          @map("emergency_contact_email") @db.VarChar(100)
  bloodGroup            String?          @map("blood_group") @db.VarChar(5)
  medicalConditions     String?          @map("medical_conditions")

  enrollmentStatus      StudentEnrollmentStatus @default(ACTIVE) @map("enrollment_status")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  // Relations
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution           Institution      @relation(fields: [institutionId], references: [id])
  academicYears         StudentAcademicYear[] // Academic progression history
  parents               Parent[]
  
  // Legacy relations - will be removed in migration
  course                Course?          @relation(fields: [courseId], references: [id])
  classDivision         ClassDivision?   @relation(fields: [classDivisionId], references: [id])
  academicRecords       AcademicRecord[]
  attendance            Attendance[]
  enrollments           Enrollment[]
  examResults           ExamResult[]
  submissions           Submission[]
  studentFees           StudentFee[]
  payments              Payment[]
  bookIssues            BookIssue[]
  bookReservations      BookReservation[]
  gatePasses            GatePass[]
  studentProgress       StudentProgress[]
  careerGuidance        CareerGuidance[]
  applications          Application[]

  @@map("students")
}

// New StudentAcademicYear model - Central academic progression tracking
model StudentAcademicYear {
  id                    Int              @id @default(autoincrement())
  studentId             Int              @map("student_id")
  academicYearId        Int              @map("academic_year_id")

  // Academic context for this year
  classLevel            Int              @map("class_level") // 1, 2, 3, 4, 5, etc.
  section               String?          @db.VarChar(10) // A, B, C
  rollNumber            String           @map("roll_number") @db.VarChar(50)
  classDivisionId       Int?             @map("class_division_id")
  classTeacherId        Int?             @map("class_teacher_id")

  // Roll number variants for this year
  currentRollNumber     String?          @map("current_roll_number") @db.VarChar(50)
  boardRollNumber       String?          @map("board_roll_number") @db.VarChar(50)

  // Academic performance summary
  promotionStatus       PromotionStatus  @default(IN_PROGRESS) @map("promotion_status")
  finalGrade            String?          @db.VarChar(5) @map("final_grade")
  finalPercentage       Decimal?         @db.Decimal(5,2) @map("final_percentage")
  attendancePercentage  Decimal?         @db.Decimal(5,2) @map("attendance_percentage")
  totalWorkingDays      Int?             @default(0) @map("total_working_days")
  totalDaysPresent      Int?             @default(0) @map("total_days_present")

  // Dates
  enrollmentDate        DateTime         @map("enrollment_date") @db.Date
  completionDate        DateTime?        @map("completion_date") @db.Date
  
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  // Relations - Link ALL academic activities to specific academic year
  student               Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear          AcademicYear     @relation(fields: [academicYearId], references: [id])
  classDivision         ClassDivision?   @relation(fields: [classDivisionId], references: [id])
  classTeacher          Teacher?         @relation("StudentAcademicYearClassTeacher", fields: [classTeacherId], references: [id])

  // Academic activities for this year - will be added in migration
  examResults           ExamResult[]     @relation("StudentAcademicYearExamResults")
  submissions           Submission[]     @relation("StudentAcademicYearSubmissions")
  academicRecords       AcademicRecord[] @relation("StudentAcademicYearRecords")
  attendance            Attendance[]     @relation("StudentAcademicYearAttendance")
  enrollments           Enrollment[]     @relation("StudentAcademicYearEnrollments")
  studentFees           StudentFee[]     @relation("StudentAcademicYearFees")

  @@unique([studentId, academicYearId])
  @@unique([academicYearId, classDivisionId, rollNumber])
  @@map("student_academic_years")
}

model Teacher {
  id                Int              @id @default(autoincrement())
  userId            Int              @unique @map("user_id")
  institutionId     Int              @map("institution_id")
  employeeId        String           @unique @map("employee_id") @db.VarChar(50)
  designation       String?          @db.VarChar(100)
  specialization    String?          @db.VarChar(200)
  qualification     String?          @db.VarChar(200)
  experienceYears   Int              @default(0) @map("experience_years")
  joinDate          DateTime?        @map("join_date") @db.Date
  salary            Decimal?         @db.Decimal(12, 2)
  employmentType    EmploymentType   @default(FULL_TIME) @map("employment_type")
  officeLocation    String?          @map("office_location") @db.VarChar(100)
  officeHours       String?          @map("office_hours") @db.VarChar(200)
  researchInterests String?          @map("research_interests")
  publications      String?
  employmentStatus  TeacherEmploymentStatus @default(ACTIVE) @map("employment_status")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution       Institution      @relation(fields: [institutionId], references: [id])
  attendanceMarked  Attendance[]     @relation("AttendanceMarker")
  classSections     ClassSection[]
  classDivisions    ClassDivision[]  // Simple class divisions as class teacher
  examinations      Examination[]
  examResults       ExamResult[]
  assignments       Assignment[]
  submissions       Submission[]
  careerGuidance    CareerGuidance[]
  timeTables        TimeTable[]
  teacherSubjects   TeacherSubject[]
  substitutions     TeacherSubstitution[] @relation("TeacherSubstitute")
  classTeacher      ClassTeacher[]
  questionPapers    QuestionPaper[]
  studentAcademicYears StudentAcademicYear[] @relation("StudentAcademicYearClassTeacher")

  @@map("teachers")
}

model Parent {
  id                Int            @id @default(autoincrement())
  userId            Int            @unique @map("user_id")
  studentId         Int            @map("student_id")
  relation          ParentRelation
  occupation        String?        @db.VarChar(100)
  annualIncome      Decimal?       @map("annual_income") @db.Decimal(12, 2)
  educationLevel    String?        @map("education_level") @db.VarChar(50)
  isPrimaryContact  Boolean        @default(false) @map("is_primary_contact")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Relations
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  student           Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("parents")
}

model Staff {
  id                Int              @id @default(autoincrement())
  userId            Int              @unique @map("user_id")
  institutionId     Int              @map("institution_id")
  employeeId        String           @unique @map("employee_id") @db.VarChar(50)
  staffType         StaffType        @map("staff_type")
  designation       String           @db.VarChar(100)
  department        String?          @db.VarChar(100)
  joinDate          DateTime?        @map("join_date") @db.Date
  salary            Decimal?         @db.Decimal(12, 2)
  employmentType    EmploymentType   @default(FULL_TIME) @map("employment_type")
  workingHours      String?          @map("working_hours") @db.VarChar(100)
  reportingManager  Int?             @map("reporting_manager")
  skills            String[]         // Array of skills
  qualifications    String?          @db.VarChar(300)
  experience        String?          @db.VarChar(300)
  emergencyContact  String?          @map("emergency_contact") @db.VarChar(15)
  address           String?
  employmentStatus  StaffEmploymentStatus @default(ACTIVE) @map("employment_status")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution       Institution      @relation(fields: [institutionId], references: [id])
  attendance        StaffAttendance[]
  leaves            StaffLeave[]
  assignments       StaffAssignment[]

  @@map("staff")
}

// User Enums
enum StudentType {
  REGULAR
  TRANSFER
  EXCHANGE
}

enum PromotionStatus {
  IN_PROGRESS    // Currently studying
  PROMOTED       // Promoted to next class
  REPEATED       // Repeating same class
  FAILED         // Failed, needs to repeat
  TRANSFERRED    // Transferred to another school
  COMPLETED      // Completed final year
}

enum ResidentialStatus {
  DAY_SCHOLAR
  HOSTELER
}

enum StudentEnrollmentStatus {
  PENDING_ENROLLMENT   // Admitted but not enrolled
  ACTIVE              // Currently enrolled
  ALUMNI              // Graduated
  DROPOUT             // Left school
  TRANSFERRED         // Moved to another institution
  SUSPENDED           // Academically suspended
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  VISITING
}

enum TeacherEmploymentStatus {
  ACTIVE              // Currently employed
  ON_LEAVE            // Temporary leave
  RESIGNED            // Employment ended
  RETIRED             // Retired
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum StaffType {
  ADMINISTRATIVE
  TECHNICAL
  SUPPORT
  SECURITY
  MAINTENANCE
  TRANSPORT
  CLEANING
  CAFETERIA
  MEDICAL
  OTHER
}

enum StaffEmploymentStatus {
  ACTIVE              // Currently employed
  INACTIVE            // Temporarily inactive
  ON_LEAVE            // Temporary leave
  RESIGNED            // Employment ended
  TERMINATED          // Terminated
  RETIRED             // Retired
}
