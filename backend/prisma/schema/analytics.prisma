// ============================================================================
// ANALYTICS AND DASHBOARD MODELS
// ============================================================================

model StudentProgress {
  id                Int              @id @default(autoincrement())
  studentId         Int              @map("student_id")
  subjectId         Int              @map("subject_id")
  semesterId        Int              @map("semester_id")
  academicYearId    Int              @map("academic_year_id")
  overallGrade      String?          @map("overall_grade") @db.VarChar(5)
  gradePoints       Decimal?         @map("grade_points") @db.Decimal(4, 2)
  attendancePercentage Decimal?      @map("attendance_percentage") @db.Decimal(5, 2)
  assignmentScore   Decimal?         @map("assignment_score") @db.Decimal(6, 2)
  examScore         Decimal?         @map("exam_score") @db.Decimal(6, 2)
  participationScore Decimal?        @map("participation_score") @db.Decimal(6, 2)
  status            ProgressStatus   @default(ON_TRACK)
  strengths         String[]         // Array of strengths
  areasForImprovement String[]       @map("areas_for_improvement") // Array of improvement areas
  teacherComments   String?          @map("teacher_comments")
  parentComments    String?          @map("parent_comments")
  lastUpdated       DateTime         @default(now()) @map("last_updated")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject           Subject          @relation(fields: [subjectId], references: [id])
  semester          Semester         @relation(fields: [semesterId], references: [id])

  @@unique([studentId, subjectId, semesterId], name: "unique_student_progress")
  @@map("student_progress")
}

model CareerGuidance {
  id                Int              @id @default(autoincrement())
  studentId         Int              @map("student_id")
  teacherId         Int              @map("teacher_id")
  sessionDate       DateTime         @map("session_date") @db.Date
  sessionType       String           @map("session_type") @db.VarChar(50) // "individual", "group", "workshop"
  interests         String[]         // Array of student interests
  strengths         String[]         // Array of student strengths
  careerGoals       String?          @map("career_goals") @db.VarChar(500)
  recommendedPaths  String[]         @map("recommended_paths") // Array of recommended career paths
  actionPlan        String?          @map("action_plan") @db.VarChar(1000)
  followUpDate      DateTime?        @map("follow_up_date") @db.Date
  teacherNotes      String?          @map("teacher_notes")
  studentFeedback   String?          @map("student_feedback")
  status            String           @default("ACTIVE") @db.VarChar(20)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher           Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("career_guidance")
}

model Application {
  id                Int              @id @default(autoincrement())
  studentId         Int              @map("student_id")
  applicationType   String           @map("application_type") @db.VarChar(50) // "scholarship", "transfer", "leave", "certificate"
  title             String           @db.VarChar(200)
  description       String?
  supportingDocuments String[]       @map("supporting_documents") // Array of document URLs
  status            ApplicationStatus @default(PENDING)
  submittedDate     DateTime         @default(now()) @map("submitted_date")
  reviewedBy        Int?             @map("reviewed_by")
  reviewedDate      DateTime?        @map("reviewed_date")
  reviewComments    String?          @map("review_comments")
  approvedDate      DateTime?        @map("approved_date")
  rejectionReason   String?          @map("rejection_reason")
  priority          String           @default("NORMAL") @db.VarChar(20) // "LOW", "NORMAL", "HIGH", "URGENT"
  metadata          Json?            // Additional application-specific data
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reviewer          User?            @relation(fields: [reviewedBy], references: [id], onDelete: Cascade)

  @@map("applications")
}

model SystemAlert {
  id                Int              @id @default(autoincrement())
  institutionId     Int              @map("institution_id")
  alertType         String           @map("alert_type") @db.VarChar(50) // "system", "security", "academic", "financial"
  title             String           @db.VarChar(200)
  message           String
  severity          AlertSeverity
  category          String?          @db.VarChar(50)
  isActive          Boolean          @default(true) @map("is_active")
  isResolved        Boolean          @default(false) @map("is_resolved")
  resolvedBy        Int?             @map("resolved_by")
  resolvedAt        DateTime?        @map("resolved_at")
  resolutionNotes   String?          @map("resolution_notes")
  metadata          Json?            // Additional alert data
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  resolver          User?            @relation(fields: [resolvedBy], references: [id], onDelete: Cascade)

  @@map("system_alerts")
}

// Analytics Enums
enum ProgressStatus {
  EXCELLENT
  GOOD
  ON_TRACK
  NEEDS_IMPROVEMENT
  AT_RISK
  FAILING
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}
