// ============================================================================
// ACADEMIC RECORDS AND ATTENDANCE
// ============================================================================

model AcademicRecord {
  id          Int      @id @default(autoincrement())
  studentId   Int      @map("student_id")
  semesterId  Int      @map("semester_id")
  subjectId   Int      @map("subject_id") // Subject (individual paper/subject)
  marksObtained Decimal? @map("marks_obtained") @db.Decimal(6, 2)
  maxMarks    Decimal? @map("max_marks") @db.Decimal(6, 2)
  grade       String?  @db.VarChar(5)
  gradePoints Decimal? @map("grade_points") @db.Decimal(4, 2)
  creditsEarned Int?   @map("credits_earned")
  status      AcademicRecordStatus @default(PASSED)
  remarks     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semester    Semester @relation(fields: [semesterId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])

  @@unique([studentId, semesterId, subjectId], name: "unique_record")
  @@map("academic_records")
}

model Attendance {
  id          Int            @id @default(autoincrement())
  studentId   Int            @map("student_id")
  sectionId   Int            @map("section_id")
  date        DateTime       @db.Date
  status      AttendanceStatus
  remarks     String?
  markedBy    Int            @map("marked_by")
  markedAt    DateTime       @default(now()) @map("marked_at")

  // Relations
  student     Student        @relation(fields: [studentId], references: [id])
  section     ClassSection   @relation(fields: [sectionId], references: [id])
  marker      Teacher        @relation("AttendanceMarker", fields: [markedBy], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId, date], name: "unique_attendance")
  @@map("attendance")
}

model ClassSection {
  id          Int      @id @default(autoincrement())
  subjectId   Int      @map("subject_id") // Subject being taught in this section
  semesterId  Int      @map("semester_id")
  teacherId   Int      @map("teacher_id")
  sectionName String   @map("section_name") @db.VarChar(10)
  maxCapacity Int      @default(50) @map("max_capacity")
  currentEnrollment Int @default(0) @map("current_enrollment")
  roomNumber  String?  @map("room_number") @db.VarChar(50)
  schedule    Json?    // {"Monday": "09:00-10:30", "Wednesday": "09:00-10:30"}
  status      ClassSectionStatus @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  subject     Subject  @relation(fields: [subjectId], references: [id])
  semester    Semester @relation(fields: [semesterId], references: [id])
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  attendance  Attendance[]
  assignments Assignment[]

  @@map("class_sections")
}

// Simple Class Divisions - For basic school organization (e.g., "Class I - Section A")
// This is separate from ClassSection which is subject-specific
model ClassDivision {
  id          Int      @id @default(autoincrement())
  courseId    Int      @map("course_id") // Course this division belongs to
  sectionName String   @map("section_name") @db.VarChar(10) // e.g., "A", "B", "Alpha", "Beta"
  teacherId   Int?     @map("teacher_id") // Optional class teacher
  maxCapacity Int      @default(50) @map("max_capacity")
  roomNumber  String?  @map("room_number") @db.VarChar(50)
  schedule    String?  @db.VarChar(200) // Optional schedule (e.g., "Mon-Fri 9:00-10:00 AM")
  status      ClassDivisionStatus @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  course      Course   @relation(fields: [courseId], references: [id])
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  students    Student[] // Students assigned to this division

  @@unique([courseId, sectionName], name: "unique_course_section")
  @@map("class_divisions")
}

model Enrollment {
  id                Int              @id @default(autoincrement())
  studentId         Int              @map("student_id")
  subjectId         Int              @map("subject_id") // Subject student is enrolled in
  semesterId        Int              @map("semester_id")
  enrollmentDate    DateTime         @default(now()) @map("enrollment_date") @db.Date
  enrollmentStatus  EnrollmentStatus @default(ENROLLED) @map("enrollment_status")
  grade             String?          @db.VarChar(5)
  creditsEarned     Int              @default(0) @map("credits_earned")
  attendancePercentage Decimal?      @map("attendance_percentage") @db.Decimal(5, 2)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject           Subject          @relation(fields: [subjectId], references: [id])
  semester          Semester         @relation(fields: [semesterId], references: [id])

  @@unique([studentId, subjectId, semesterId], name: "unique_enrollment")
  @@map("enrollments")
}

// Records Enums
enum AcademicRecordStatus {
  PASSED
  FAILED
  INCOMPLETE
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ClassSectionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

enum ClassDivisionStatus {
  ACTIVE
  INACTIVE
}

enum EnrollmentStatus {
  ENROLLED
  DROPPED
  COMPLETED
  FAILED
}
