// ============================================================================
// CORE SYSTEM MODELS
// ============================================================================

model User {
  id                Int      @id @default(autoincrement())
  uuid              String?  @unique @default(uuid()) @db.Uuid
  edverseId         String?  @unique @map("edverse_id") @db.VarChar(20)
  firstName         String   @db.VarChar(50)
  lastName          String   @db.VarChar(50)
  name              String   @db.VarChar(100) // Keep for backward compatibility
  email             String?  @unique @db.VarChar(100)
  phone             String?  @db.VarChar(15)
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  roleId            Int      @map("role_id")
  emailVerified     Boolean  @default(false) @map("email_verified")
  phoneVerified     Boolean  @default(false) @map("phone_verified")
  twoFactorEnabled  Boolean  @default(false) @map("two_factor_enabled")
  isTemporaryPassword Boolean @default(false) @map("is_temporary_password")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  lastLogin         DateTime? @map("last_login")
  loginAttempts     Int      @default(0) @map("login_attempts")
  accountLocked     Boolean  @default(false) @map("account_locked")
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  role              Role     @relation(fields: [roleId], references: [id])
  student           Student?
  teacher           Teacher?
  parent            Parent?
  staff             Staff?
  payments          Payment[]
  noticesCreated    Notice[]
  announcementsCreated Announcement[]
  messagesSent      Message[]        @relation("MessageSender")
  messagesReceived  Message[]        @relation("MessageReceiver")
  groupsCreated     MessageGroup[]
  groupMemberships  GroupMember[]
  noticeReadReceipts NoticeReadReceipt[]
  booksAdded        Book[]
  bookIssues        BookIssue[]      @relation("BookIssuer")
  bookReturns       BookIssue[]      @relation("BookReturner")
  libraryTransactions LibraryTransaction[]
  visitorPassApprovals VisitorPass[]
  staffAttendanceMarked StaffAttendance[]
  staffLeaveApprovals StaffLeave[]
  staffAssignments  StaffAssignment[]
  gatePassRequests  GatePass[]       @relation("GatePassRequester")
  gatePassParentApprovals GatePass[] @relation("GatePassParentApprover")
  gatePassTeacherApprovals GatePass[] @relation("GatePassTeacherApprover")
  gatePassAdminApprovals GatePass[]   @relation("GatePassAdminApprover")
  substitutionRequests TeacherSubstitution[] @relation("SubstitutionRequester")
  substitutionApprovals TeacherSubstitution[] @relation("SubstitutionApprover")
  applicationApprovals Application[]
  dashboardStats    DashboardStats[]
  systemAlertsResolved SystemAlert[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  roleName    String   @unique @map("role_name") @db.VarChar(50)
  description String?
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  users User[]

  @@map("roles")
}

model Institution {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(4)
  name            String           @db.VarChar(200)
  type            InstitutionType
  address         String?
  city            String?          @db.VarChar(100)
  state           String?          @db.VarChar(100)
  country         String?          @db.VarChar(100)
  postalCode      String?          @map("postal_code") @db.VarChar(20)
  phone           String?          @db.VarChar(15)
  email           String?          @db.VarChar(100)
  website         String?          @db.VarChar(200)
  establishedYear Int?             @map("established_year")
  accreditation   String?          @db.VarChar(100)
  status          InstitutionStatus @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  students        Student[]
  courses         Course[] // Courses (degree programs/streams)
  teachers        Teacher[]
  staff           Staff[]
  academicYears   AcademicYear[]
  feeStructures   FeeStructure[]
  notices         Notice[]
  announcements   Announcement[]
  messageGroups   MessageGroup[]
  books           Book[]
  librarySettings LibrarySettings[]
  gatePasses      GatePass[]
  gatePassSettings GatePassSettings[]
  visitorPasses   VisitorPass[]
  timeTables      TimeTable[]
  timeSlots       TimeSlot[]
  rooms           Room[]
  dashboardStats  DashboardStats[]
  performanceMetrics PerformanceMetrics[]
  systemAlerts    SystemAlert[]
  gradingConfig   InstitutionGradingConfig?

  @@map("institutions")
}

model InstitutionGradingConfig {
  id                      Int      @id @default(autoincrement())
  institutionId           Int      @unique @map("institution_id")
  
  // Grading Formula Weights (must sum to 100)
  attendanceWeight        Decimal  @default(10) @map("attendance_weight") @db.Decimal(5, 2)
  assignmentWeight        Decimal  @default(30) @map("assignment_weight") @db.Decimal(5, 2)
  examWeight              Decimal  @default(50) @map("exam_weight") @db.Decimal(5, 2)
  participationWeight     Decimal  @default(10) @map("participation_weight") @db.Decimal(5, 2)
  
  // Grade Boundaries (percentage scores)
  gradeAPlusThreshold     Decimal  @default(93) @map("grade_a_plus_threshold") @db.Decimal(5, 2)
  gradeAThreshold         Decimal  @default(85) @map("grade_a_threshold") @db.Decimal(5, 2)
  gradeBPlusThreshold     Decimal  @default(77) @map("grade_b_plus_threshold") @db.Decimal(5, 2)
  gradeBThreshold         Decimal  @default(70) @map("grade_b_threshold") @db.Decimal(5, 2)
  gradeCThreshold         Decimal  @default(60) @map("grade_c_threshold") @db.Decimal(5, 2)
  // Below C threshold = D
  
  // Grade Points Mapping
  gradeAPlusPoints        Decimal  @default(4.0) @map("grade_a_plus_points") @db.Decimal(3, 1)
  gradeAPoints            Decimal  @default(3.7) @map("grade_a_points") @db.Decimal(3, 1)
  gradeBPlusPoints        Decimal  @default(3.3) @map("grade_b_plus_points") @db.Decimal(3, 1)
  gradeBPoints            Decimal  @default(3.0) @map("grade_b_points") @db.Decimal(3, 1)
  gradeCPoints            Decimal  @default(2.0) @map("grade_c_points") @db.Decimal(3, 1)
  gradeDPoints            Decimal  @default(1.0) @map("grade_d_points") @db.Decimal(3, 1)
  
  // Risk Status Thresholds
  atRiskAttendance        Decimal  @default(75) @map("at_risk_attendance") @db.Decimal(5, 2)
  atRiskAssignment        Decimal  @default(60) @map("at_risk_assignment") @db.Decimal(5, 2)
  atRiskExam              Decimal  @default(60) @map("at_risk_exam") @db.Decimal(5, 2)
  atRiskGradePoints       Decimal  @default(2.0) @map("at_risk_grade_points") @db.Decimal(3, 1)
  
  needsImprovementAttendance  Decimal  @default(85) @map("needs_improvement_attendance") @db.Decimal(5, 2)
  needsImprovementAssignment  Decimal  @default(70) @map("needs_improvement_assignment") @db.Decimal(5, 2)
  needsImprovementExam        Decimal  @default(70) @map("needs_improvement_exam") @db.Decimal(5, 2)
  needsImprovementGradePoints Decimal  @default(3.0) @map("needs_improvement_grade_points") @db.Decimal(3, 1)
  
  excellentAttendance     Decimal  @default(95) @map("excellent_attendance") @db.Decimal(5, 2)
  excellentAssignment     Decimal  @default(90) @map("excellent_assignment") @db.Decimal(5, 2)
  excellentExam           Decimal  @default(90) @map("excellent_exam") @db.Decimal(5, 2)
  excellentGradePoints    Decimal  @default(3.7) @map("excellent_grade_points") @db.Decimal(3, 1)
  
  goodAttendance          Decimal  @default(90) @map("good_attendance") @db.Decimal(5, 2)
  goodAssignment          Decimal  @default(80) @map("good_assignment") @db.Decimal(5, 2)
  goodExam                Decimal  @default(80) @map("good_exam") @db.Decimal(5, 2)
  goodGradePoints         Decimal  @default(3.3) @map("good_grade_points") @db.Decimal(3, 1)
  
  // Metadata
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  
  // Relations
  institution             Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  
  @@map("institution_grading_configs")
}

// Core System Enums
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InstitutionType {
  SCHOOL
  COLLEGE
  UNIVERSITY
  INSTITUTE
}

enum InstitutionStatus {
  ACTIVE
  INACTIVE
}
