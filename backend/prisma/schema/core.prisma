// ============================================================================
// CORE SYSTEM MODELS
// ============================================================================

model User {
  id                Int      @id @default(autoincrement())
  uuid              String?  @unique @default(uuid()) @db.Uuid
  edverseId         String?  @unique @map("edverse_id") @db.VarChar(20)
  firstName         String   @db.VarChar(50)
  lastName          String   @db.VarChar(50)
  name              String   @db.VarChar(100) // Keep for backward compatibility
  email             String?  @unique @db.VarChar(100)
  phone             String?  @db.VarChar(15)
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  roleId            Int      @map("role_id")
  emailVerified     Boolean  @default(false) @map("email_verified")
  phoneVerified     Boolean  @default(false) @map("phone_verified")
  twoFactorEnabled  Boolean  @default(false) @map("two_factor_enabled")
  isTemporaryPassword Boolean @default(false) @map("is_temporary_password")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  lastLogin         DateTime? @map("last_login")
  loginAttempts     Int      @default(0) @map("login_attempts")
  accountLocked     Boolean  @default(false) @map("account_locked")
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  role              Role     @relation(fields: [roleId], references: [id])
  student           Student?
  teacher           Teacher?
  parent            Parent?
  staff             Staff?
  payments          Payment[]
  noticesCreated    Notice[]
  announcementsCreated Announcement[]
  messagesSent      Message[]        @relation("MessageSender")
  messagesReceived  Message[]        @relation("MessageReceiver")
  groupsCreated     MessageGroup[]
  groupMemberships  GroupMember[]
  noticeReadReceipts NoticeReadReceipt[]
  booksAdded        Book[]
  bookIssues        BookIssue[]      @relation("BookIssuer")
  bookReturns       BookIssue[]      @relation("BookReturner")
  libraryTransactions LibraryTransaction[]
  visitorPassApprovals VisitorPass[]
  staffAttendanceMarked StaffAttendance[]
  staffLeaveApprovals StaffLeave[]
  staffAssignments  StaffAssignment[]
  gatePassRequests  GatePass[]       @relation("GatePassRequester")
  gatePassParentApprovals GatePass[] @relation("GatePassParentApprover")
  gatePassTeacherApprovals GatePass[] @relation("GatePassTeacherApprover")
  gatePassAdminApprovals GatePass[]   @relation("GatePassAdminApprover")
  substitutionRequests TeacherSubstitution[] @relation("SubstitutionRequester")
  substitutionApprovals TeacherSubstitution[] @relation("SubstitutionApprover")
  applicationApprovals Application[]
  dashboardStats    DashboardStats[]
  systemAlertsResolved SystemAlert[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  roleName    String   @unique @map("role_name") @db.VarChar(50)
  description String?
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  users User[]

  @@map("roles")
}

model Institution {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(200)
  type            InstitutionType
  address         String?
  city            String?          @db.VarChar(100)
  state           String?          @db.VarChar(100)
  country         String?          @db.VarChar(100)
  postalCode      String?          @map("postal_code") @db.VarChar(20)
  phone           String?          @db.VarChar(15)
  email           String?          @db.VarChar(100)
  website         String?          @db.VarChar(200)
  establishedYear Int?             @map("established_year")
  accreditation   String?          @db.VarChar(100)
  status          InstitutionStatus @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  students        Student[]
  programs        Program[]
  teachers        Teacher[]
  staff           Staff[]
  academicYears   AcademicYear[]
  feeStructures   FeeStructure[]
  notices         Notice[]
  announcements   Announcement[]
  messageGroups   MessageGroup[]
  books           Book[]
  librarySettings LibrarySettings[]
  gatePasses      GatePass[]
  gatePassSettings GatePassSettings[]
  visitorPasses   VisitorPass[]
  timeTables      TimeTable[]
  timeSlots       TimeSlot[]
  subjects        Subject[]
  rooms           Room[]
  dashboardStats  DashboardStats[]
  performanceMetrics PerformanceMetrics[]
  systemAlerts    SystemAlert[]

  @@map("institutions")
}

// Core System Enums
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InstitutionType {
  SCHOOL
  COLLEGE
  UNIVERSITY
  INSTITUTE
}

enum InstitutionStatus {
  ACTIVE
  INACTIVE
}
