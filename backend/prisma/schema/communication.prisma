// ============================================================================
// NOTICE BOARD AND COMMUNICATION MODELS
// ============================================================================

model Notice {
  id                Int              @id @default(autoincrement())
  institutionId     Int              @map("institution_id")
  title             String           @db.VarChar(200)
  content           String
  noticeType        NoticeType       @map("notice_type")
  priority          NoticePriority   @default(MEDIUM)
  targetAudience    String[]         // Array of roles: ["student", "teacher", "parent"]
  departmentIds     Int[]            @map("department_ids") // Specific departments if applicable
  programIds        Int[]            @map("program_ids")    // Specific programs if applicable
  classIds          Int[]            @map("class_ids")      // Specific classes if applicable
  attachmentUrl     String?          @map("attachment_url") @db.VarChar(500)
  publishDate       DateTime         @default(now()) @map("publish_date")
  expiryDate        DateTime?        @map("expiry_date")
  isActive          Boolean          @default(true) @map("is_active")
  isPinned          Boolean          @default(false) @map("is_pinned")
  createdBy         Int              @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  creator           User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  readReceipts      NoticeReadReceipt[]

  @@map("notices")
}

model NoticeReadReceipt {
  id                Int              @id @default(autoincrement())
  noticeId          Int              @map("notice_id")
  userId            Int              @map("user_id")
  readAt            DateTime         @default(now()) @map("read_at")

  // Relations
  notice            Notice           @relation(fields: [noticeId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId], name: "unique_notice_read")
  @@map("notice_read_receipts")
}

model Announcement {
  id                Int              @id @default(autoincrement())
  institutionId     Int              @map("institution_id")
  title             String           @db.VarChar(200)
  content           String
  announcementType  AnnouncementType @map("announcement_type")
  priority          NoticePriority   @default(MEDIUM)
  targetAudience    String[]         // Array of roles
  isEmergency       Boolean          @default(false) @map("is_emergency")
  attachmentUrl     String?          @map("attachment_url") @db.VarChar(500)
  publishDate       DateTime         @default(now()) @map("publish_date")
  expiryDate        DateTime?        @map("expiry_date")
  isActive          Boolean          @default(true) @map("is_active")
  createdBy         Int              @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  creator           User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model Message {
  id                Int              @id @default(autoincrement())
  senderId          Int              @map("sender_id")
  receiverId        Int?             @map("receiver_id")
  groupId           Int?             @map("group_id")
  subject           String?          @db.VarChar(200)
  content           String
  messageType       MessageType      @map("message_type")
  priority          MessagePriority  @default(NORMAL)
  attachmentUrl     String?          @map("attachment_url") @db.VarChar(500)
  isRead            Boolean          @default(false) @map("is_read")
  readAt            DateTime?        @map("read_at")
  sentAt            DateTime         @default(now()) @map("sent_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  // Relations
  sender            User             @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver          User?            @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  group             MessageGroup?    @relation(fields: [groupId], references: [id])

  @@map("messages")
}

model MessageGroup {
  id                Int              @id @default(autoincrement())
  name              String           @db.VarChar(100)
  description       String?
  groupType         GroupType        @map("group_type")
  institutionId     Int              @map("institution_id")
  createdBy         Int              @map("created_by")
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  creator           User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  members           GroupMember[]
  messages          Message[]

  @@map("message_groups")
}

model GroupMember {
  id                Int              @id @default(autoincrement())
  groupId           Int              @map("group_id")
  userId            Int              @map("user_id")
  role              GroupRole        @default(MEMBER)
  joinedAt          DateTime         @default(now()) @map("joined_at")

  // Relations
  group             MessageGroup     @relation(fields: [groupId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId], name: "unique_group_member")
  @@map("group_members")
}

// Communication Enums
enum NoticeType {
  GENERAL
  ACADEMIC
  EXAMINATION
  ADMISSION
  EVENT
  HOLIDAY
  EMERGENCY
  MAINTENANCE
}

enum AnnouncementType {
  GENERAL
  ACADEMIC
  EVENT
  ACHIEVEMENT
  ALERT
  EMERGENCY
}

enum NoticePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageType {
  PERSONAL
  GROUP
  BROADCAST
  SYSTEM
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum GroupType {
  CLASS
  DEPARTMENT
  PROGRAM
  CUSTOM
  PARENT_TEACHER
  STUDENT_GROUP
}

enum GroupRole {
  ADMIN
  MODERATOR
  MEMBER
}
