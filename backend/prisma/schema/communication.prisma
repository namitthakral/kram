// ============================================================================
// UNIFIED COMMUNICATION MODELS (Phase 2: Merged notices & announcements)
// ============================================================================

model Communication {
  id                Int                      @id @default(autoincrement())
  institutionId     Int                      @map("institution_id")
  title             String                   @db.VarChar(200)
  content           String
  communicationType CommunicationType        @map("communication_type")
  priority          CommunicationPriority    @default(MEDIUM)
  targetAudience    String[]                 @map("target_audience") // Array of roles: ["student", "teacher", "parent"]
  
  // Optional targeting fields (for granular control)
  departmentIds     Int[]                    @map("department_ids") // Specific departments
  programIds        Int[]                    @map("program_ids")    // Specific programs
  classIds          Int[]                    @map("class_ids")      // Specific classes
  
  // Flags and metadata
  isEmergency       Boolean                  @default(false) @map("is_emergency")
  isPinned          Boolean                  @default(false) @map("is_pinned")
  isActive          Boolean                  @default(true) @map("is_active")
  
  // Attachments and dates
  attachmentUrl     String?                  @map("attachment_url") @db.VarChar(500)
  publishDate       DateTime                 @default(now()) @map("publish_date")
  expiryDate        DateTime?                @map("expiry_date")
  
  // Audit fields
  createdBy         Int                      @map("created_by")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  // Relations
  institution       Institution              @relation(fields: [institutionId], references: [id])
  creator           User                     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  readReceipts      CommunicationReadReceipt[]

  @@map("communications")
}

model CommunicationReadReceipt {
  id                Int              @id @default(autoincrement())
  communicationId   Int              @map("communication_id")
  userId            Int              @map("user_id")
  readAt            DateTime         @default(now()) @map("read_at")

  // Relations
  communication     Communication    @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communicationId, userId], name: "unique_communication_read")
  @@map("communication_read_receipts")
}

// ============================================================================
// MESSAGING SYSTEM (unchanged)
// ============================================================================

model Message {
  id                Int              @id @default(autoincrement())
  senderId          Int              @map("sender_id")
  receiverId        Int?             @map("receiver_id")
  groupId           Int?             @map("group_id")
  subject           String?          @db.VarChar(200)
  content           String
  messageType       MessageType      @map("message_type")
  priority          MessagePriority  @default(NORMAL)
  attachmentUrl     String?          @map("attachment_url") @db.VarChar(500)
  isRead            Boolean          @default(false) @map("is_read")
  readAt            DateTime?        @map("read_at")
  sentAt            DateTime         @default(now()) @map("sent_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  // Relations
  sender            User             @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver          User?            @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  group             MessageGroup?    @relation(fields: [groupId], references: [id])

  @@map("messages")
}

model MessageGroup {
  id                Int              @id @default(autoincrement())
  name              String           @db.VarChar(100)
  description       String?
  groupType         GroupType        @map("group_type")
  institutionId     Int              @map("institution_id")
  createdBy         Int              @map("created_by")
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  creator           User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  members           GroupMember[]
  messages          Message[]

  @@map("message_groups")
}

model GroupMember {
  id                Int              @id @default(autoincrement())
  groupId           Int              @map("group_id")
  userId            Int              @map("user_id")
  role              GroupRole        @default(MEMBER)
  joinedAt          DateTime         @default(now()) @map("joined_at")

  // Relations
  group             MessageGroup     @relation(fields: [groupId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId], name: "unique_group_member")
  @@map("group_members")
}

// ============================================================================
// UNIFIED COMMUNICATION ENUMS
// ============================================================================

// Merged from NoticeType and AnnouncementType
enum CommunicationType {
  GENERAL
  ACADEMIC
  EXAMINATION
  ADMISSION
  EVENT
  HOLIDAY
  EMERGENCY
  MAINTENANCE
  ACHIEVEMENT
  ALERT
}

// Renamed from NoticePriority (was shared by both)
enum CommunicationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================================================
// MESSAGING ENUMS (unchanged)
// ============================================================================

enum MessageType {
  PERSONAL
  GROUP
  BROADCAST
  SYSTEM
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum GroupType {
  CLASS
  DEPARTMENT
  PROGRAM
  CUSTOM
  PARENT_TEACHER
  STUDENT_GROUP
}

enum GroupRole {
  ADMIN
  MODERATOR
  MEMBER
}
