// ============================================================================
// TIMETABLE AND SCHEDULE MODELS
// ============================================================================
//
// Subject model here is used for timetabling and teacher assignments
// This is separate from Course model (which stores academic subjects)
// Both represent "Subject" in Indian context but serve different purposes
// ============================================================================

model TimeTable {
  id                Int              @id @default(autoincrement())
  institutionId     Int              @map("institution_id")
  academicYearId    Int              @map("academic_year_id")
  semesterId        Int              @map("semester_id")
  classId           Int?             @map("class_id") // For school classes
  courseId          Int?             @map("course_id") // For courses (programs/streams)
  section           String?          @db.VarChar(10)
  dayOfWeek         DayOfWeek        @map("day_of_week")
  timeSlotId        Int              @map("time_slot_id")
  subjectId         Int              @map("subject_id")
  teacherId         Int              @map("teacher_id")
  roomId            Int?             @map("room_id")
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  academicYear      AcademicYear     @relation(fields: [academicYearId], references: [id])
  semester          Semester         @relation(fields: [semesterId], references: [id])
  course            Course?          @relation(fields: [courseId], references: [id])
  timeSlot          TimeSlot         @relation(fields: [timeSlotId], references: [id])
  subject           Subject          @relation(fields: [subjectId], references: [id])
  teacher           Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  room              Room?            @relation(fields: [roomId], references: [id])
  substitutions     TeacherSubstitution[]

  @@unique([institutionId, academicYearId, semesterId, courseId, section, dayOfWeek, timeSlotId], name: "unique_timetable_slot")
  @@map("timetables")
}

model TimeSlot {
  id                Int              @id @default(autoincrement())
  institutionId     Int              @map("institution_id")
  slotName          String           @map("slot_name") @db.VarChar(50) // "Period 1", "Morning Break", etc.
  startTime         DateTime         @map("start_time") @db.Time
  endTime           DateTime         @map("end_time") @db.Time
  slotType          SlotType         @map("slot_type")
  duration          Int              // Duration in minutes
  isActive          Boolean          @default(true) @map("is_active")
  sortOrder         Int              @map("sort_order")
  createdAt         DateTime         @default(now()) @map("created_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  timetables        TimeTable[]

  @@map("time_slots")
}

// ScheduleSubject table removed - using unified Subject table instead
// TimeTable, TeacherSubject, etc. now reference the main Subject model

model Room {
  id                Int              @id @default(autoincrement())
  institutionId     Int              @map("institution_id")
  roomNumber        String           @map("room_number") @db.VarChar(20)
  roomName          String?          @map("room_name") @db.VarChar(100)
  roomType          RoomType         @map("room_type")
  building          String?          @db.VarChar(100)
  floor             String?          @db.VarChar(20)
  capacity          Int?
  facilities        String[]         // Array of facilities like "Projector", "AC", "Whiteboard"
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  institution       Institution      @relation(fields: [institutionId], references: [id])
  timetables        TimeTable[]

  @@unique([institutionId, roomNumber], name: "unique_room_number")
  @@map("rooms")
}

model TeacherSubject {
  id                Int              @id @default(autoincrement())
  teacherId         Int              @map("teacher_id")
  subjectId         Int              @map("subject_id")
  academicYearId    Int              @map("academic_year_id")
  isPrimary         Boolean          @default(false) @map("is_primary") // Primary teacher for the subject
  createdAt         DateTime         @default(now()) @map("created_at")

  // Relations
  teacher           Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject           Subject          @relation(fields: [subjectId], references: [id])
  academicYear      AcademicYear     @relation(fields: [academicYearId], references: [id])

  @@unique([teacherId, subjectId, academicYearId], name: "unique_teacher_subject")
  @@map("teacher_subjects")
}

model TeacherSubstitution {
  id                Int              @id @default(autoincrement())
  originalTimetableId Int            @map("original_timetable_id")
  substituteTeacherId Int            @map("substitute_teacher_id")
  date              DateTime         @db.Date
  reason            String           @db.VarChar(200)
  status            SubstitutionStatus @default(PENDING)
  requestedBy       Int              @map("requested_by")
  approvedBy        Int?             @map("approved_by")
  approvedAt        DateTime?        @map("approved_at")
  remarks           String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  originalTimetable TimeTable        @relation(fields: [originalTimetableId], references: [id])
  substituteTeacher Teacher          @relation("TeacherSubstitute", fields: [substituteTeacherId], references: [id], onDelete: Cascade)
  requester         User             @relation("SubstitutionRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  approver          User?            @relation("SubstitutionApprover", fields: [approvedBy], references: [id], onDelete: Cascade)

  @@map("teacher_substitutions")
}

model ClassTeacher {
  id                Int              @id @default(autoincrement())
  teacherId         Int              @map("teacher_id")
  courseId          Int?             @map("course_id") // Course (program/stream) for this class
  classLevel        String?          @map("class_level") @db.VarChar(20) // For schools: "Class 10", "Grade 5"
  section           String?          @db.VarChar(10)
  academicYearId    Int              @map("academic_year_id")
  isActive          Boolean          @default(true) @map("is_active")
  assignedDate      DateTime         @default(now()) @map("assigned_date")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  teacher           Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  course            Course?          @relation(fields: [courseId], references: [id])
  academicYear      AcademicYear     @relation(fields: [academicYearId], references: [id])

  @@unique([courseId, classLevel, section, academicYearId], name: "unique_class_teacher")
  @@map("class_teachers")
}

// Timetable Enums
enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SlotType {
  LECTURE
  PRACTICAL
  TUTORIAL
  BREAK
  LUNCH
  ASSEMBLY
  SPORTS
  LIBRARY
  STUDY_HALL
}

// SubjectType enum moved to academic.prisma to avoid duplication

enum RoomType {
  CLASSROOM
  LABORATORY
  LIBRARY
  AUDITORIUM
  SPORTS_ROOM
  COMPUTER_LAB
  CONFERENCE_ROOM
  STAFF_ROOM
  PRINCIPAL_OFFICE
  MEDICAL_ROOM
}

enum SubstitutionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}
