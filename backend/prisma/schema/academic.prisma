// ============================================================================
// ACADEMIC STRUCTURE MODELS
// ============================================================================
// 
// INDIAN EDUCATION SYSTEM TERMINOLOGY:
// - Program (Course in Indian context) = Degree/Stream (e.g., B.Sc. CS, Commerce, Science-Medical)
// - Course (Subject/Paper in Indian context) = Individual subject (e.g., Data Structures, Physics, English)
// 
// Note: This schema uses international terminology in database
// but APIs should expose Indian terminology for better UX
// ============================================================================

model AcademicYear {
  id           Int             @id @default(autoincrement())
  institutionId Int            @map("institution_id")
  yearName     String          @map("year_name") @db.VarChar(20)
  startDate    DateTime        @map("start_date") @db.Date
  endDate      DateTime        @map("end_date") @db.Date
  status       AcademicYearStatus @default(CURRENT)
  createdAt    DateTime        @default(now()) @map("created_at")

  // Relations
  institution  Institution     @relation(fields: [institutionId], references: [id])
  semesters    Semester[]
  feeStructures FeeStructure[]
  teacherSubjects TeacherSubject[]
  classTeachers ClassTeacher[]
  timeTables   TimeTable[]

  @@map("academic_years")
}

model Semester {
  id                Int            @id @default(autoincrement())
  academicYearId    Int            @map("academic_year_id")
  semesterName      String         @map("semester_name") @db.VarChar(50)
  semesterNumber    Int            @map("semester_number")
  startDate         DateTime       @map("start_date") @db.Date
  endDate           DateTime       @map("end_date") @db.Date
  registrationStart DateTime?      @map("registration_start") @db.Date
  registrationEnd   DateTime?      @map("registration_end") @db.Date
  status            SemesterStatus @default(UPCOMING)
  createdAt         DateTime       @default(now()) @map("created_at")

  // Relations
  academicYear      AcademicYear   @relation(fields: [academicYearId], references: [id])
  enrollments       Enrollment[]
  classSections     ClassSection[]
  examinations      Examination[]
  academicRecords   AcademicRecord[]
  studentFees       StudentFee[]
  studentProgress   StudentProgress[]
  attendanceSummary AttendanceSummary[]
  timeTables        TimeTable[]

  @@map("semesters")
}

// Course model - Represents "Course" in Indian context
// In Indian education: Course = Degree/Stream program
// Examples: 
// - Colleges: "B.Sc. Computer Science", "B.Com", "BCA", "M.Tech"
// - Schools (11-12): "Science - Medical", "Science - Non-Medical", "Commerce", "Arts"
// - Schools (K-10): Optional, can use general "Primary Education" or none
model Course {
  id                  Int            @id @default(autoincrement())
  institutionId       Int            @map("institution_id")
  name                String         @db.VarChar(200) // e.g., "B.Sc. Computer Science", "Science - Medical Stream"
  code                String?        @unique @db.VarChar(20) // e.g., "BSCS", "SCI-MED"
  degreeType          DegreeType     @map("degree_type") // For schools (11-12), use CERTIFICATE
  durationYears       Decimal?       @map("duration_years") @db.Decimal(3, 1) // e.g., 3.0 for B.Sc., 2.0 for 11-12
  totalCredits        Int?           @map("total_credits") // Optional for schools
  description         String?
  eligibilityCriteria String?        @map("eligibility_criteria") // e.g., "Passed 10th with 60%"
  status              CourseStatus   @default(ACTIVE)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Relations
  institution         Institution    @relation(fields: [institutionId], references: [id])
  subjects            Subject[]      // Subjects within this course/program
  students            Student[]
  feeStructures       FeeStructure[]
  timeTables          TimeTable[]
  classTeachers       ClassTeacher[]

  @@map("courses")
}

// Subject model - Represents "Subject/Paper" in Indian context
// In Indian education: Subject = Individual academic subject/paper
// Examples: 
// - Colleges: "Data Structures", "DBMS", "Web Development", "Organic Chemistry"
// - Schools: "English", "Hindi", "Mathematics", "Physics", "Chemistry", "Biology"
model Subject {
  id              Int          @id @default(autoincrement())
  courseId        Int?         @map("course_id") // Optional - links to Course (degree/stream)
  subjectName     String       @map("subject_name") @db.VarChar(200) // e.g., "Data Structures", "English"
  subjectCode     String       @unique @map("subject_code") @db.VarChar(20) // e.g., "CS201", "ENG101", "MATH10"
  credits         Int          // For colleges; marks/total for schools
  theoryHours     Int          @default(0) @map("theory_hours") // Lecture hours
  practicalHours  Int          @default(0) @map("practical_hours") // Lab hours
  tutorialHours   Int          @default(0) @map("tutorial_hours")
  subjectType     SubjectType  @default(CORE) @map("subject_type") // CORE, ELECTIVE
  prerequisites   String?      // JSON array of subject_ids - mainly for college
  description     String?
  syllabus        String?
  status          SubjectStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  course          Course?      @relation(fields: [courseId], references: [id]) // Links to Course (program/stream)
  academicRecords AcademicRecord[]
  classSections   ClassSection[]
  enrollments     Enrollment[]
  examinations    Examination[]
  assignments     Assignment[]
  // Timetabling and scheduling relations
  timetables      TimeTable[]
  teacherSubjects TeacherSubject[]
  studentProgress StudentProgress[]
  attendanceSummary AttendanceSummary[]

  @@map("subjects")
}

// Academic Enums
enum DegreeType {
  CERTIFICATE
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
  OTHER
}

// Course Status (was ProgramStatus)
enum CourseStatus {
  ACTIVE
  INACTIVE
}

// Subject Type (was CourseType)
// Combined from academic and timetable contexts
enum SubjectType {
  CORE
  ELECTIVE
  MINOR
  MAJOR
  OPTIONAL
  EXTRA_CURRICULAR
  LANGUAGE
  SCIENCE
  MATHEMATICS
  SOCIAL_STUDIES
  ARTS
  PHYSICAL_EDUCATION
}

// Subject Status (was CourseStatus)
enum SubjectStatus {
  ACTIVE
  INACTIVE
}

enum AcademicYearStatus {
  CURRENT
  PAST
  FUTURE
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}
