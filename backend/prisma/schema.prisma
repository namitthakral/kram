// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or "mysql", "sqlite", etc.
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-FILE SCHEMA ORGANIZATION
// ============================================================================
// This schema is automatically generated from individual files in /prisma/schema/
// To modify models, edit the individual files and run: npm run build:schema
// ============================================================================


model User {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(100)
  email             String   @unique @db.VarChar(100)
  phone             String?  @db.VarChar(15)
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  roleId            Int      @map("role_id")
  emailVerified     Boolean  @default(false) @map("email_verified")
  phoneVerified     Boolean  @default(false) @map("phone_verified")
  twoFactorEnabled  Boolean  @default(false) @map("two_factor_enabled")
  lastLogin         DateTime? @map("last_login")
  loginAttempts     Int      @default(0) @map("login_attempts")
  accountLocked     Boolean  @default(false) @map("account_locked")
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  role              Role     @relation(fields: [roleId], references: [id])
  student           Student?
  teacher           Teacher?
  parent            Parent?
  staff             Staff?
  payments          Payment[]
  noticesCreated    Notice[]
  announcementsCreated Announcement[]
  messagesSent      Message[]        @relation("MessageSender")
  messagesReceived  Message[]        @relation("MessageReceiver")
  groupsCreated     MessageGroup[]
  groupMemberships  GroupMember[]
  noticeReadReceipts NoticeReadReceipt[]
  booksAdded        Book[]
  bookIssues        BookIssue[]      @relation("BookIssuer")
  bookReturns       BookIssue[]      @relation("BookReturner")
  libraryTransactions LibraryTransaction[]
  visitorPassApprovals VisitorPass[]
  staffAttendanceMarked StaffAttendance[]
  staffLeaveApprovals StaffLeave[]
  staffAssignments  StaffAssignment[]
  gatePassRequests  GatePass[]       @relation("GatePassRequester")
  gatePassParentApprovals GatePass[] @relation("GatePassParentApprover")
  gatePassTeacherApprovals GatePass[] @relation("GatePassTeacherApprover")
  gatePassAdminApprovals GatePass[]   @relation("GatePassAdminApprover")
  substitutionRequests TeacherSubstitution[] @relation("SubstitutionRequester")
  substitutionApprovals TeacherSubstitution[] @relation("SubstitutionApprover")
  applicationApprovals Application[]
  dashboardStats    DashboardStats[]
  systemAlertsResolved SystemAlert[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  roleName    String   @unique @map("role_name") @db.VarChar(50)
  description String?
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  users User[]

  @@map("roles")
}

model Institution {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(200)
  type            InstitutionType
  address         String?
  city            String?          @db.VarChar(100)
  state           String?          @db.VarChar(100)
  country         String?          @db.VarChar(100)
  postalCode      String?          @map("postal_code") @db.VarChar(20)
  phone           String?          @db.VarChar(15)
  email           String?          @db.VarChar(100)
  website         String?          @db.VarChar(200)
  establishedYear Int?             @map("established_year")
  accreditation   String?          @db.VarChar(100)
  status          InstitutionStatus @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  students        Student[]
  programs        Program[]
  teachers        Teacher[]
  staff           Staff[]
  academicYears   AcademicYear[]
  feeStructures   FeeStructure[]
  notices         Notice[]
  announcements   Announcement[]
  messageGroups   MessageGroup[]
  books           Book[]
  librarySettings LibrarySettings[]
  gatePasses      GatePass[]
  gatePassSettings GatePassSettings[]
  visitorPasses   VisitorPass[]
  timeTables      TimeTable[]
  timeSlots       TimeSlot[]
  subjects        Subject[]
  rooms           Room[]
  dashboardStats  DashboardStats[]
  performanceMetrics PerformanceMetrics[]
  systemAlerts    SystemAlert[]

  @@map("institutions")
}

// Core System Enums
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InstitutionType {
  SCHOOL
  COLLEGE
  UNIVERSITY
  INSTITUTE
}

enum InstitutionStatus {
  ACTIVE
  INACTIVE
}


model AcademicYear {
  id           Int             @id @default(autoincrement())
  institutionId Int            @map("institution_id")
  yearName     String          @map("year_name") @db.VarChar(20)
  startDate    DateTime        @map("start_date") @db.Date
  endDate      DateTime        @map("end_date") @db.Date
  status       AcademicYearStatus @default(CURRENT)
  createdAt    DateTime        @default(now()) @map("created_at")

  // Relations
  institution  Institution     @relation(fields: [institutionId], references: [id])
  semesters    Semester[]
  feeStructures FeeStructure[]
  teacherSubjects TeacherSubject[]
  classTeachers ClassTeacher[]
  timeTables   TimeTable[]

  @@map("academic_years")
}

model Semester {
  id                Int            @id @default(autoincrement())
  academicYearId    Int            @map("academic_year_id")
  semesterName      String         @map("semester_name") @db.VarChar(50)
  semesterNumber    Int            @map("semester_number")
  startDate         DateTime       @map("start_date") @db.Date
  endDate           DateTime       @map("end_date") @db.Date
  registrationStart DateTime?      @map("registration_start") @db.Date
  registrationEnd   DateTime?      @map("registration_end") @db.Date
  status            SemesterStatus @default(UPCOMING)
  createdAt         DateTime       @default(now()) @map("created_at")

  // Relations
  academicYear      AcademicYear   @relation(fields: [academicYearId], references: [id])
  enrollments       Enrollment[]
  classSections     ClassSection[]
  examinations      Examination[]
  academicRecords   AcademicRecord[]
  studentFees       StudentFee[]
  studentProgress   StudentProgress[]
  attendanceSummary AttendanceSummary[]
  timeTables        TimeTable[]

  @@map("semesters")
}

model Program {
  id                  Int            @id @default(autoincrement())
  institutionId       Int            @map("institution_id")
  name                String         @db.VarChar(200)
  code                String?        @unique @db.VarChar(20)
  degreeType          DegreeType     @map("degree_type")
  durationYears       Decimal?       @map("duration_years") @db.Decimal(3, 1)
  totalCredits        Int?           @map("total_credits")
  description         String?
  eligibilityCriteria String?        @map("eligibility_criteria")
  status              ProgramStatus  @default(ACTIVE)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Relations
  institution         Institution    @relation(fields: [institutionId], references: [id])
  courses             Course[]
  students            Student[]
  feeStructures       FeeStructure[]
  timeTables          TimeTable[]
  classTeachers       ClassTeacher[]

  @@map("programs")
}

model Course {
  id              Int          @id @default(autoincrement())
  programId       Int?         @map("program_id")
  courseName      String       @map("course_name") @db.VarChar(200)
  courseCode      String       @unique @map("course_code") @db.VarChar(20)
  credits         Int
  lectureHours    Int          @default(0) @map("lecture_hours")
  labHours        Int          @default(0) @map("lab_hours")
  tutorialHours   Int          @default(0) @map("tutorial_hours")
  courseType      CourseType   @default(CORE) @map("course_type")
  prerequisites   String?      // JSON array of course_ids
  description     String?
  syllabus        String?
  status          CourseStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  program         Program?     @relation(fields: [programId], references: [id])
  academicRecords AcademicRecord[]
  classSections   ClassSection[]
  enrollments     Enrollment[]
  examinations    Examination[]
  assignments     Assignment[]

  @@map("courses")
}

// Academic Enums
enum DegreeType {
  CERTIFICATE
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
  OTHER
}

enum ProgramStatus {
  ACTIVE
  INACTIVE
}

enum CourseType {
  CORE
  ELECTIVE
  MINOR
  MAJOR
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

enum AcademicYearStatus {
  CURRENT
  PAST
  FUTURE
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}


model Student {
  id                    Int              @id @default(autoincrement())
  userId                Int              @unique @map("user_id")
  institutionId         Int              @map("institution_id")
  programId             Int?             @map("program_id")
  admissionNumber       String           @unique @map("admission_number") @db.VarChar(50)
  rollNumber            String?          @map("roll_number") @db.VarChar(50)
  admissionDate         DateTime?        @map("admission_date") @db.Date
  graduationDate        DateTime?        @map("graduation_date") @db.Date
  currentSemester       Int?             @map("current_semester")
  currentYear           Int?             @map("current_year")
  gradeLevel            String?          @map("grade_level") @db.VarChar(20)
  section               String?          @db.VarChar(10)
  studentType           StudentType      @default(REGULAR) @map("student_type")
  residentialStatus     ResidentialStatus @default(DAY_SCHOLAR) @map("residential_status")
  transportRequired     Boolean          @default(false) @map("transport_required")
  emergencyContactName  String?          @map("emergency_contact_name") @db.VarChar(100)
  emergencyContactPhone String?          @map("emergency_contact_phone") @db.VarChar(15)
  bloodGroup            String?          @map("blood_group") @db.VarChar(5)
  medicalConditions     String?          @map("medical_conditions")
  status                StudentStatus    @default(ACTIVE)
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  // Relations
  user                  User             @relation(fields: [userId], references: [id])
  institution           Institution      @relation(fields: [institutionId], references: [id])
  program               Program?         @relation(fields: [programId], references: [id])
  parents               Parent[]
  academicRecords       AcademicRecord[]
  attendance            Attendance[]
  enrollments           Enrollment[]
  examResults           ExamResult[]
  submissions           Submission[]
  studentFees           StudentFee[]
  payments              Payment[]
  bookIssues            BookIssue[]
  bookReservations      BookReservation[]
  libraryTransactions   LibraryTransaction[]
  gatePasses            GatePass[]
  studentProgress       StudentProgress[]
  attendanceSummary     AttendanceSummary[]
  careerGuidance        CareerGuidance[]
  applications          Application[]

  @@map("students")
}

model Teacher {
  id                Int              @id @default(autoincrement())
  userId            Int              @unique @map("user_id")
  institutionId     Int              @map("institution_id")
  employeeId        String           @unique @map("employee_id") @db.VarChar(50)
  designation       String?          @db.VarChar(100)
  specialization    String?          @db.VarChar(200)
  qualification     String?          @db.VarChar(200)
  experienceYears   Int              @default(0) @map("experience_years")
  joinDate          DateTime?        @map("join_date") @db.Date
  salary            Decimal?         @db.Decimal(12, 2)
  employmentType    EmploymentType   @default(FULL_TIME) @map("employment_type")
  officeLocation    String?          @map("office_location") @db.VarChar(100)
  officeHours       String?          @map("office_hours") @db.VarChar(200)
  researchInterests String?          @map("research_interests")
  publications      String?
  status            TeacherStatus    @default(ACTIVE)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  user              User             @relation(fields: [userId], references: [id])
  institution       Institution      @relation(fields: [institutionId], references: [id])
  attendanceMarked  Attendance[]     @relation("AttendanceMarker")
  classSections     ClassSection[]
  examinations      Examination[]
  examResults       ExamResult[]
  assignments       Assignment[]
  submissions       Submission[]
  careerGuidance    CareerGuidance[]
  timeTables        TimeTable[]
  teacherSubjects   TeacherSubject[]
  substitutions     TeacherSubstitution[] @relation("TeacherSubstitute")
  classTeacher      ClassTeacher[]

  @@map("teachers")
}

model Parent {
  id                Int            @id @default(autoincrement())
  userId            Int            @unique @map("user_id")
  studentId         Int            @map("student_id")
  relation          ParentRelation
  occupation        String?        @db.VarChar(100)
  annualIncome      Decimal?       @map("annual_income") @db.Decimal(12, 2)
  educationLevel    String?        @map("education_level") @db.VarChar(50)
  isPrimaryContact  Boolean        @default(false) @map("is_primary_contact")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Relations
  user              User           @relation(fields: [userId], references: [id])
  student           Student        @relation(fields: [studentId], references: [id])

  @@map("parents")
}

model Staff {
  id                Int              @id @default(autoincrement())
  userId            Int              @unique @map("user_id")
  institutionId     Int              @map("institution_id")
  employeeId        String           @unique @map("employee_id") @db.VarChar(50)
  staffType         StaffType        @map("staff_type")
  designation       String           @db.VarChar(100)
  department        String?          @db.VarChar(100)
  joinDate          DateTime?        @map("join_date") @db.Date
  salary            Decimal?         @db.Decimal(12, 2)
  employmentType    EmploymentType   @default(FULL_TIME) @map("employment_type")
  workingHours      String?          @map("working_hours") @db.VarChar(100)
  reportingManager  Int?             @map("reporting_manager")
  skills            String[]         // Array of skills
  qualifications    String?          @db.VarChar(300)
  experience        String?          @db.VarChar(300)
  emergencyContact  String?          @map("emergency_contact") @db.VarChar(15)
  address           String?
  status            StaffStatus      @default(ACTIVE)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  user              User             @relation(fields: [userId], references: [id])
  institution       Institution      @relation(fields: [institutionId], references: [id])
  attendance        StaffAttendance[]
  leaves            StaffLeave[]
  assignments       StaffAssignment[]

  @@map("staff")
}

// User Enums
enum StudentType {
  REGULAR
  TRANSFER
  EXCHANGE
}

enum ResidentialStatus {
  DAY_SCHOLAR
  HOSTELER
}

enum StudentStatus {
  ACTIVE
  ALUMNI
  DROPOUT
  TRANSFERRED
  SUSPENDED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  VISITING
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  RETIRED
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum StaffType {
  ADMINISTRATIVE
  TECHNICAL
  SUPPORT
  SECURITY
  MAINTENANCE
  TRANSPORT
  CLEANING
  CAFETERIA
  MEDICAL
  OTHER
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
  RETIRED
}


model AcademicRecord {
  id          Int      @id @default(autoincrement())
  studentId   Int      @map("student_id")
  semesterId  Int      @map("semester_id")
  courseId    Int      @map("course_id")
  marksObtained Decimal? @map("marks_obtained") @db.Decimal(6, 2)
  maxMarks    Decimal? @map("max_marks") @db.Decimal(6, 2)
  grade       String?  @db.VarChar(5)
  gradePoints Decimal? @map("grade_points") @db.Decimal(4, 2)
  creditsEarned Int?   @map("credits_earned")
  status      AcademicRecordStatus @default(PASSED)
  remarks     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  student     Student  @relation(fields: [studentId], references: [id])
  semester    Semester @relation(fields: [semesterId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])

  @@unique([studentId, semesterId, courseId], name: "unique_record")
  @@map("academic_records")
}

model Attendance {
  id          Int            @id @default(autoincrement())
  studentId   Int            @map("student_id")
  sectionId   Int            @map("section_id")
  date        DateTime       @db.Date
  status      AttendanceStatus
  remarks     String?
  markedBy    Int            @map("marked_by")
  markedAt    DateTime       @default(now()) @map("marked_at")

  // Relations
  student     Student        @relation(fields: [studentId], references: [id])
  section     ClassSection   @relation(fields: [sectionId], references: [id])
  marker      Teacher        @relation("AttendanceMarker", fields: [markedBy], references: [id])

  @@unique([studentId, sectionId, date], name: "unique_attendance")
  @@map("attendance")
}

model ClassSection {
  id          Int      @id @default(autoincrement())
  courseId    Int      @map("course_id")
  semesterId  Int      @map("semester_id")
  teacherId   Int      @map("teacher_id")
  sectionName String   @map("section_name") @db.VarChar(10)
  maxCapacity Int      @default(50) @map("max_capacity")
  currentEnrollment Int @default(0) @map("current_enrollment")
  roomNumber  String?  @map("room_number") @db.VarChar(50)
  schedule    Json?    // {"Monday": "09:00-10:30", "Wednesday": "09:00-10:30"}
  status      ClassSectionStatus @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  course      Course   @relation(fields: [courseId], references: [id])
  semester    Semester @relation(fields: [semesterId], references: [id])
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  attendance  Attendance[]
  assignments Assignment[]

  @@map("class_sections")
}

model Enrollment {
  id                Int              @id @default(autoincrement())
  studentId         Int              @map("student_id")
  courseId          Int              @map("course_id")
  semesterId        Int              @map("semester_id")
  enrollmentDate    DateTime         @default(now()) @map("enrollment_date") @db.Date
  enrollmentStatus  EnrollmentStatus @default(ENROLLED) @map("enrollment_status")
  grade             String?          @db.VarChar(5)
  creditsEarned     Int              @default(0) @map("credits_earned")
  attendancePercentage Decimal?      @map("attendance_percentage") @db.Decimal(5, 2)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  student           Student          @relation(fields: [studentId], references: [id])
  course            Course           @relation(fields: [courseId], references: [id])
  semester          Semester         @relation(fields: [semesterId], references: [id])

  @@unique([studentId, courseId, semesterId], name: "unique_enrollment")
  @@map("enrollments")
}

// Records Enums
enum AcademicRecordStatus {
  PASSED
  FAILED
  INCOMPLETE
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ClassSectionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

enum EnrollmentStatus {
  ENROLLED
  DROPPED
  COMPLETED
  FAILED
}


model Examination {
  id                  Int              @id @default(autoincrement())
  courseId            Int              @map("course_id")
  semesterId          Int              @map("semester_id")
  examName            String           @map("exam_name") @db.VarChar(100)
  examType            ExamType         @map("exam_type")
  examDate            DateTime?        @map("exam_date") @db.Date
  startTime           DateTime?        @map("start_time") @db.Time
  durationMinutes     Int?             @map("duration_minutes")
  totalMarks          Int              @map("total_marks")
  passingMarks        Int?             @map("passing_marks")
  weightagePercentage Decimal?         @map("weightage_percentage") @db.Decimal(5, 2)
  instructions        String?
  venue               String?          @db.VarChar(100)
  status              ExamStatus       @default(SCHEDULED)
  createdBy           Int              @map("created_by")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  // Relations
  course              Course           @relation(fields: [courseId], references: [id])
  semester            Semester         @relation(fields: [semesterId], references: [id])
  creator             Teacher          @relation(fields: [createdBy], references: [id])
  results             ExamResult[]

  @@map("examinations")
}

model ExamResult {
  id          Int      @id @default(autoincrement())
  examId      Int      @map("exam_id")
  studentId   Int      @map("student_id")
  marksObtained Decimal? @map("marks_obtained") @db.Decimal(6, 2)
  grade       String?  @db.VarChar(5)
  rankInClass Int?     @map("rank_in_class")
  remarks     String?
  isAbsent    Boolean  @default(false) @map("is_absent")
  evaluatedBy Int?     @map("evaluated_by")
  evaluatedAt DateTime? @map("evaluated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  exam        Examination @relation(fields: [examId], references: [id])
  student     Student     @relation(fields: [studentId], references: [id])
  evaluator   Teacher?    @relation(fields: [evaluatedBy], references: [id])

  @@unique([examId, studentId], name: "unique_result")
  @@map("exam_results")
}

model Assignment {
  id                      Int                @id @default(autoincrement())
  courseId                Int                @map("course_id")
  sectionId               Int?               @map("section_id")
  teacherId               Int                @map("teacher_id")
  title                   String             @db.VarChar(200)
  description             String?
  instructions            String?
  maxMarks                Int                @default(100) @map("max_marks")
  weightagePercentage     Decimal?           @map("weightage_percentage") @db.Decimal(5, 2)
  assignedDate            DateTime           @default(now()) @map("assigned_date") @db.Date
  dueDate                 DateTime           @map("due_date")
  lateSubmissionAllowed   Boolean            @default(true) @map("late_submission_allowed")
  latePenaltyPercentage   Decimal            @default(0) @map("late_penalty_percentage") @db.Decimal(5, 2)
  attachmentUrl           String?            @map("attachment_url") @db.VarChar(500)
  status                  AssignmentStatus   @default(DRAFT)
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")

  // Relations
  course                  Course             @relation(fields: [courseId], references: [id])
  section                 ClassSection?      @relation(fields: [sectionId], references: [id])
  teacher                 Teacher            @relation(fields: [teacherId], references: [id])
  submissions             Submission[]

  @@map("assignments")
}

model Submission {
  id            Int              @id @default(autoincrement())
  assignmentId  Int              @map("assignment_id")
  studentId     Int              @map("student_id")
  fileUrl       String?          @map("file_url") @db.VarChar(500)
  fileName      String?          @map("file_name") @db.VarChar(255)
  fileSize      Int?             @map("file_size")
  submissionText String?
  submittedAt   DateTime         @default(now()) @map("submitted_at")
  isLate        Boolean          @default(false) @map("is_late")
  marksObtained Decimal?         @map("marks_obtained") @db.Decimal(6, 2)
  feedback      String?
  gradedBy      Int?             @map("graded_by")
  gradedAt      DateTime?        @map("graded_at")
  status        SubmissionStatus @default(SUBMITTED)
  version       Int              @default(1)

  // Relations
  assignment    Assignment       @relation(fields: [assignmentId], references: [id])
  student       Student          @relation(fields: [studentId], references: [id])
  grader        Teacher?         @relation(fields: [gradedBy], references: [id])

  @@unique([assignmentId, studentId, version], name: "unique_submission")
  @@map("submissions")
}

// Assessment Enums
enum ExamType {
  QUIZ
  MIDTERM
  FINAL
  ASSIGNMENT
  PROJECT
  PRACTICAL
}

enum ExamStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
