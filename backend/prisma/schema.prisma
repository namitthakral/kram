model Communication {
  id                Int                      @id @default(autoincrement())
  institutionId     Int                      @map("institution_id")
  title             String                   @db.VarChar(200)
  content           String
  communicationType CommunicationType        @map("communication_type")
  priority          CommunicationPriority    @default(MEDIUM)
  targetAudience    String[]                 // Array of roles: ["student", "teacher", "parent"]
  
  // Optional targeting fields (for granular control)
  departmentIds     Int[]                    @map("department_ids") // Specific departments
  programIds        Int[]                    @map("program_ids")    // Specific programs
  classIds          Int[]                    @map("class_ids")      // Specific classes
  
  // Flags and metadata
  isEmergency       Boolean                  @default(false) @map("is_emergency")
  isPinned          Boolean                  @default(false) @map("is_pinned")
  isActive          Boolean                  @default(true) @map("is_active")
  
  // Attachments and dates
  attachmentUrl     String?                  @map("attachment_url") @db.VarChar(500)
  publishDate       DateTime                 @default(now()) @map("publish_date")
  expiryDate        DateTime?                @map("expiry_date")
  
  // Audit fields
  createdBy         Int                      @map("created_by")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  // Relations
  institution       Institution              @relation(fields: [institutionId], references: [id])
  creator           User                     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  readReceipts      CommunicationReadReceipt[]

  @@map("communications")
}

