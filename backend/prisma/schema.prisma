model AcademicRecord {
  id          Int      @id @default(autoincrement())
  studentId   Int      @map("student_id")
  semesterId  Int      @map("semester_id")
  subjectId   Int      @map("subject_id") // Subject (individual paper/subject)
  marksObtained Decimal? @map("marks_obtained") @db.Decimal(6, 2)
  maxMarks    Decimal? @map("max_marks") @db.Decimal(6, 2)
  grade       String?  @db.VarChar(5)
  gradePoints Decimal? @map("grade_points") @db.Decimal(4, 2)
  creditsEarned Int?   @map("credits_earned")
