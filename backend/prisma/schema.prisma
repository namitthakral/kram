generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or "mysql", "sqlite", etc.
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-FILE SCHEMA ORGANIZATION
// ============================================================================
// This schema is automatically generated from individual files in /prisma/schema/
// To modify models, edit the individual files and run: npm run build:schema
// ============================================================================


model User {
  id                Int      @id @default(autoincrement())
  uuid              String?  @unique @default(uuid()) @db.Uuid
  kramid            String?  @unique @map("kramid") @db.VarChar(20)
  firstName         String   @db.VarChar(50)
  lastName          String   @db.VarChar(50)
  name              String   @db.VarChar(100) // Keep for backward compatibility
  email             String?  @unique @db.VarChar(100)
  phone             String?  @db.VarChar(15)
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  roleId            Int      @map("role_id")
  institutionId     Int?     @map("institution_id")
  emailVerified     Boolean  @default(false) @map("email_verified")
  phoneVerified     Boolean  @default(false) @map("phone_verified")
  twoFactorEnabled  Boolean  @default(false) @map("two_factor_enabled")
  isTemporaryPassword Boolean @default(false) @map("is_temporary_password")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  lastLogin         DateTime? @map("last_login")
  loginAttempts     Int      @default(0) @map("login_attempts")
  accountLocked     Boolean  @default(false) @map("account_locked")
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  role              Role         @relation(fields: [roleId], references: [id])
  institution       Institution? @relation(fields: [institutionId], references: [id])
  student           Student?
  teacher           Teacher?
  parent            Parent?
  staff             Staff?
  payments          Payment[]
  communicationsCreated Communication[]
  messagesSent      Message[]        @relation("MessageSender")
  messagesReceived  Message[]        @relation("MessageReceiver")
  groupsCreated     MessageGroup[]
  groupMemberships  GroupMember[]
  communicationReadReceipts CommunicationReadReceipt[]
  booksAdded        Book[]
  bookIssues        BookIssue[]      @relation("BookIssuer")
  bookReturns       BookIssue[]      @relation("BookReturner")
  visitorPassApprovals VisitorPass[]
  staffAttendanceMarked StaffAttendance[]
  staffLeaveApprovals StaffLeave[]
  staffAssignments  StaffAssignment[]
  gatePassRequests  GatePass[]       @relation("GatePassRequester")
  gatePassParentApprovals GatePass[] @relation("GatePassParentApprover")
  gatePassTeacherApprovals GatePass[] @relation("GatePassTeacherApprover")
  gatePassAdminApprovals GatePass[]   @relation("GatePassAdminApprover")
  substitutionRequests TeacherSubstitution[] @relation("SubstitutionRequester")
  substitutionApprovals TeacherSubstitution[] @relation("SubstitutionApprover")
  applicationApprovals Application[]
  systemAlertsResolved SystemAlert[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  roleName    String   @unique @map("role_name") @db.VarChar(50)
  description String?
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  users User[]

  @@map("roles")
}

model Institution {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(4)
  name            String           @db.VarChar(200)
  type            InstitutionType
  address         String?
  city            String?          @db.VarChar(100)
  state           String?          @db.VarChar(100)
  country         String?          @db.VarChar(100)
  postalCode      String?          @map("postal_code") @db.VarChar(20)
  phone           String?          @db.VarChar(15)
  email           String?          @db.VarChar(100)
  website         String?          @db.VarChar(200)
  establishedYear Int?             @map("established_year")
  accreditation   String?          @db.VarChar(100)
  status          InstitutionStatus @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  users           User[]
  students        Student[]
  courses         Course[] // Courses (degree programs/streams)
  teachers        Teacher[]
  staff           Staff[]
  academicYears   AcademicYear[]
  feeStructures   FeeStructure[]
  communications  Communication[]
  messageGroups   MessageGroup[]
  books           Book[]
  librarySettings LibrarySettings[]
  gatePasses      GatePass[]
  gatePassSettings GatePassSettings[]
  visitorPasses   VisitorPass[]
  timeTables      TimeTable[]
  timeSlots       TimeSlot[]
  rooms           Room[]
  systemAlerts    SystemAlert[]
  gradingConfig   InstitutionGradingConfig?
  idConfig        InstitutionIdConfig?

  @@map("institutions")
}

model InstitutionGradingConfig {
  id                      Int      @id @default(autoincrement())
  institutionId           Int      @unique @map("institution_id")
  
  // Grading Formula Weights (must sum to 100)
  attendanceWeight        Decimal  @default(10) @map("attendance_weight") @db.Decimal(5, 2)
  assignmentWeight        Decimal  @default(30) @map("assignment_weight") @db.Decimal(5, 2)
  examWeight              Decimal  @default(50) @map("exam_weight") @db.Decimal(5, 2)
  participationWeight     Decimal  @default(10) @map("participation_weight") @db.Decimal(5, 2)
  
  // Grade Boundaries (percentage scores)
  gradeAPlusThreshold     Decimal  @default(93) @map("grade_a_plus_threshold") @db.Decimal(5, 2)
  gradeAThreshold         Decimal  @default(85) @map("grade_a_threshold") @db.Decimal(5, 2)
  gradeBPlusThreshold     Decimal  @default(77) @map("grade_b_plus_threshold") @db.Decimal(5, 2)
  gradeBThreshold         Decimal  @default(70) @map("grade_b_threshold") @db.Decimal(5, 2)
  gradeCThreshold         Decimal  @default(60) @map("grade_c_threshold") @db.Decimal(5, 2)
  // Below C threshold = D
  
  // Grade Points Mapping
  gradeAPlusPoints        Decimal  @default(4.0) @map("grade_a_plus_points") @db.Decimal(3, 1)
  gradeAPoints            Decimal  @default(3.7) @map("grade_a_points") @db.Decimal(3, 1)
  gradeBPlusPoints        Decimal  @default(3.3) @map("grade_b_plus_points") @db.Decimal(3, 1)
  gradeBPoints            Decimal  @default(3.0) @map("grade_b_points") @db.Decimal(3, 1)
  gradeCPoints            Decimal  @default(2.0) @map("grade_c_points") @db.Decimal(3, 1)
  gradeDPoints            Decimal  @default(1.0) @map("grade_d_points") @db.Decimal(3, 1)
  
  // Risk Status Thresholds
  atRiskAttendance        Decimal  @default(75) @map("at_risk_attendance") @db.Decimal(5, 2)
  atRiskAssignment        Decimal  @default(60) @map("at_risk_assignment") @db.Decimal(5, 2)
  atRiskExam              Decimal  @default(60) @map("at_risk_exam") @db.Decimal(5, 2)
  atRiskGradePoints       Decimal  @default(2.0) @map("at_risk_grade_points") @db.Decimal(3, 1)
  
  needsImprovementAttendance  Decimal  @default(85) @map("needs_improvement_attendance") @db.Decimal(5, 2)
  needsImprovementAssignment  Decimal  @default(70) @map("needs_improvement_assignment") @db.Decimal(5, 2)
  needsImprovementExam        Decimal  @default(70) @map("needs_improvement_exam") @db.Decimal(5, 2)
  needsImprovementGradePoints Decimal  @default(3.0) @map("needs_improvement_grade_points") @db.Decimal(3, 1)
  
  excellentAttendance     Decimal  @default(95) @map("excellent_attendance") @db.Decimal(5, 2)
  excellentAssignment     Decimal  @default(90) @map("excellent_assignment") @db.Decimal(5, 2)
  excellentExam           Decimal  @default(90) @map("excellent_exam") @db.Decimal(5, 2)
  excellentGradePoints    Decimal  @default(3.7) @map("excellent_grade_points") @db.Decimal(3, 1)
  
  goodAttendance          Decimal  @default(90) @map("good_attendance") @db.Decimal(5, 2)
  goodAssignment          Decimal  @default(80) @map("good_assignment") @db.Decimal(5, 2)
  goodExam                Decimal  @default(80) @map("good_exam") @db.Decimal(5, 2)
  goodGradePoints         Decimal  @default(3.3) @map("good_grade_points") @db.Decimal(3, 1)
  
  // Metadata
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  
  // Relations
  institution             Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  
  @@map("institution_grading_configs")
}

// Institution ID Format Configuration
// Allows each institution to define their own ID formats
model InstitutionIdConfig {
  id                      Int      @id @default(autoincrement())
  institutionId           Int      @unique @map("institution_id")
  
  // ID Format Templates
  // Available placeholders: {YEAR}, {YY}, {INST}, {COURSE}, {BRANCH}, {SECTION}, {SEQ:N}, {MONTH}, {MM}
  admissionNumberFormat   String   @default("{YEAR}/{COURSE}/{SEQ:5}") @map("admission_number_format") @db.VarChar(100)
  rollNumberFormat        String   @default("{COURSE}-{SECTION}-{SEQ:3}") @map("roll_number_format") @db.VarChar(100)
  teacherEmployeeIdFormat String   @default("EMP-{YEAR}-{SEQ:5}") @map("teacher_employee_id_format") @db.VarChar(100)
  staffEmployeeIdFormat   String   @default("STF-{YEAR}-{SEQ:5}") @map("staff_employee_id_format") @db.VarChar(100)
  
  // Sequence Configuration
  sequenceResetPolicy     SequenceResetPolicy @default(YEARLY) @map("sequence_reset_policy")
  
  // Current Sequence Counters (reset based on policy)
  admissionSeqYear        Int      @default(0) @map("admission_seq_year")
  admissionSeqCounter     Int      @default(0) @map("admission_seq_counter")
  rollSeqYear             Int      @default(0) @map("roll_seq_year")
  rollSeqCounter          Int      @default(0) @map("roll_seq_counter")
  teacherSeqYear          Int      @default(0) @map("teacher_seq_year")
  teacherSeqCounter       Int      @default(0) @map("teacher_seq_counter")
  staffSeqYear            Int      @default(0) @map("staff_seq_year")
  staffSeqCounter         Int      @default(0) @map("staff_seq_counter")
  
  // Metadata
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  
  // Relations
  institution             Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  
  @@map("institution_id_configs")
}

enum SequenceResetPolicy {
  YEARLY    // Reset sequence every year
  NEVER     // Never reset, continuously incrementing
  MONTHLY   // Reset sequence every month
}

// Core System Enums
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InstitutionType {
  SCHOOL
  COLLEGE
  UNIVERSITY
  INSTITUTE
}

enum InstitutionStatus {
  ACTIVE
  INACTIVE
}


// ============================================================================
// ACADEMIC STRUCTURE MODELS
// ============================================================================
// 
// INDIAN EDUCATION SYSTEM TERMINOLOGY:
// - Program (Course in Indian context) = Degree/Stream (e.g., B.Sc. CS, Commerce, Science-Medical)
// - Course (Subject/Paper in Indian context) = Individual subject (e.g., Data Structures, Physics, English)
// 
// Note: This schema uses international terminology in database
// but APIs should expose Indian terminology for better UX
// ============================================================================

model AcademicYear {
  id           Int             @id @default(autoincrement())
  institutionId Int            @map("institution_id")
  yearName     String          @map("year_name") @db.VarChar(20)
  startDate    DateTime        @map("start_date") @db.Date
  endDate      DateTime        @map("end_date") @db.Date
  status       AcademicYearStatus @default(CURRENT)
  createdAt    DateTime        @default(now()) @map("created_at")

  // Relations
  institution  Institution     @relation(fields: [institutionId], references: [id])
  semesters    Semester[]
  feeStructures FeeStructure[]
  teacherSubjects TeacherSubject[]
  classTeachers ClassTeacher[]
  timeTables   TimeTable[]

  @@map("academic_years")
}

model Semester {
  id                Int            @id @default(autoincrement())
  academicYearId    Int            @map("academic_year_id")
  semesterName      String         @map("semester_name") @db.VarChar(50)
  semesterNumber    Int            @map("semester_number")
  startDate         DateTime       @map("start_date") @db.Date
  endDate           DateTime       @map("end_date") @db.Date
  registrationStart DateTime?      @map("registration_start") @db.Date
  registrationEnd   DateTime?      @map("registration_end") @db.Date
  status            SemesterStatus @default(UPCOMING)
  createdAt         DateTime       @default(now()) @map("created_at")

  // Relations
  academicYear      AcademicYear   @relation(fields: [academicYearId], references: [id])
  enrollments       Enrollment[]
  classSections     ClassSection[]
  examinations      Examination[]
  academicRecords   AcademicRecord[]
  studentFees       StudentFee[]
  studentProgress   StudentProgress[]
  timeTables        TimeTable[]

  @@map("semesters")
}

// Course model - Represents "Course" in Indian context
// In Indian education: Course = Degree/Stream program
// Examples: 
// - Colleges: "B.Sc. Computer Science", "B.Com", "BCA", "M.Tech"
// - Schools (11-12): "Science - Medical", "Science - Non-Medical", "Commerce", "Arts"
// - Schools (K-10): Optional, can use general "Primary Education" or none
model Course {
  id                  Int            @id @default(autoincrement())
  institutionId       Int            @map("institution_id")
  name                String         @db.VarChar(200) // e.g., "B.Sc. Computer Science", "Science - Medical Stream"
  code                String?        @unique @db.VarChar(20) // e.g., "BSCS", "SCI-MED"
  degreeType          DegreeType     @map("degree_type") // For schools (11-12), use CERTIFICATE
  durationYears       Decimal?       @map("duration_years") @db.Decimal(3, 1) // e.g., 3.0 for B.Sc., 2.0 for 11-12
  totalCredits        Int?           @map("total_credits") // Optional for schools
  description         String?
  eligibilityCriteria String?        @map("eligibility_criteria") // e.g., "Passed 10th with 60%"
  status              CourseStatus   @default(ACTIVE)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Relations
  institution         Institution    @relation(fields: [institutionId], references: [id])
  subjects            Subject[]      // Subjects within this course/program
  students            Student[]
  feeStructures       FeeStructure[]
  timeTables          TimeTable[]
  classTeachers       ClassTeacher[]

  @@map("courses")
}

// Subject model - Represents "Subject/Paper" in Indian context
// In Indian education: Subject = Individual academic subject/paper
// Examples: 
// - Colleges: "Data Structures", "DBMS", "Web Development", "Organic Chemistry"
// - Schools: "English", "Hindi", "Mathematics", "Physics", "Chemistry", "Biology"
model Subject {
  id              Int          @id @default(autoincrement())
  courseId        Int?         @map("course_id") // Optional - links to Course (degree/stream)
  subjectName     String       @map("subject_name") @db.VarChar(200) // e.g., "Data Structures", "English"
  subjectCode     String       @unique @map("subject_code") @db.VarChar(20) // e.g., "CS201", "ENG101", "MATH10"
  credits         Int          // For colleges; marks/total for schools
  theoryHours     Int          @default(0) @map("theory_hours") // Lecture hours
  practicalHours  Int          @default(0) @map("practical_hours") // Lab hours
  tutorialHours   Int          @default(0) @map("tutorial_hours")
  subjectType     SubjectType  @default(CORE) @map("subject_type") // CORE, ELECTIVE
  prerequisites   String?      // JSON array of subject_ids - mainly for college
  description     String?
  syllabus        String?
  status          SubjectStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  course          Course?      @relation(fields: [courseId], references: [id]) // Links to Course (program/stream)
  academicRecords AcademicRecord[]
  classSections   ClassSection[]
  enrollments     Enrollment[]
  examinations    Examination[]
  assignments     Assignment[]
  // Timetabling and scheduling relations
  timetables      TimeTable[]
  teacherSubjects TeacherSubject[]
  studentProgress StudentProgress[]

  @@map("subjects")
}

// Academic Enums
enum DegreeType {
  CERTIFICATE
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
  OTHER
}

// Course Status (was ProgramStatus)
enum CourseStatus {
  ACTIVE
  INACTIVE
}

// Subject Type (was CourseType)
// Combined from academic and timetable contexts
enum SubjectType {
  CORE
  ELECTIVE
  MINOR
  MAJOR
  OPTIONAL
  EXTRA_CURRICULAR
  LANGUAGE
  SCIENCE
  MATHEMATICS
  SOCIAL_STUDIES
  ARTS
  PHYSICAL_EDUCATION
}

// Subject Status (was CourseStatus)
enum SubjectStatus {
  ACTIVE
  INACTIVE
}

enum AcademicYearStatus {
  CURRENT
  PAST
  FUTURE
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}


model Student {
  id                    Int              @id @default(autoincrement())
  userId                Int              @unique @map("user_id")
  institutionId         Int              @map("institution_id")
  courseId              Int?             @map("course_id") // Course (program/stream) student is enrolled in
  admissionNumber       String           @unique @map("admission_number") @db.VarChar(50)
  rollNumber            String?          @map("roll_number") @db.VarChar(50)
  admissionDate         DateTime?        @map("admission_date") @db.Date
  graduationDate        DateTime?        @map("graduation_date") @db.Date
  currentSemester       Int?             @map("current_semester")
  currentYear           Int?             @map("current_year")
  gradeLevel            String?          @map("grade_level") @db.VarChar(20)
  section               String?          @db.VarChar(10)
  studentType           StudentType      @default(REGULAR) @map("student_type")
  residentialStatus     ResidentialStatus @default(DAY_SCHOLAR) @map("residential_status")
  transportRequired     Boolean          @default(false) @map("transport_required")
  emergencyContactName  String?          @map("emergency_contact_name") @db.VarChar(100)
  emergencyContactPhone String?          @map("emergency_contact_phone") @db.VarChar(15)
  emergencyContactEmail String?          @map("emergency_contact_email") @db.VarChar(100)
  bloodGroup            String?          @map("blood_group") @db.VarChar(5)
  medicalConditions     String?          @map("medical_conditions")
  status                StudentStatus    @default(ACTIVE)
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  // Relations
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution           Institution      @relation(fields: [institutionId], references: [id])
  course                Course?          @relation(fields: [courseId], references: [id])
  parents               Parent[]
  academicRecords       AcademicRecord[]
  attendance            Attendance[]
  enrollments           Enrollment[]
  examResults           ExamResult[]
  submissions           Submission[]
  studentFees           StudentFee[]
  payments              Payment[]
  bookIssues            BookIssue[]
  bookReservations      BookReservation[]
  gatePasses            GatePass[]
  studentProgress       StudentProgress[]
  careerGuidance        CareerGuidance[]
  applications          Application[]

  @@map("students")
}

model Teacher {
  id                Int              @id @default(autoincrement())
  userId            Int              @unique @map("user_id")
  institutionId     Int              @map("institution_id")
  employeeId        String           @unique @map("employee_id") @db.VarChar(50)
  designation       String?          @db.VarChar(100)
  specialization    String?          @db.VarChar(200)
  qualification     String?          @db.VarChar(200)
  experienceYears   Int              @default(0) @map("experience_years")
  joinDate          DateTime?        @map("join_date") @db.Date
  salary            Decimal?         @db.Decimal(12, 2)
  employmentType    EmploymentType   @default(FULL_TIME) @map("employment_type")
  officeLocation    String?          @map("office_location") @db.VarChar(100)
  officeHours       String?          @map("office_hours") @db.VarChar(200)
  researchInterests String?          @map("research_interests")
  publications      String?
  status            TeacherStatus    @default(ACTIVE)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution       Institution      @relation(fields: [institutionId], references: [id])
  attendanceMarked  Attendance[]     @relation("AttendanceMarker")
  classSections     ClassSection[]
  examinations      Examination[]
  examResults       ExamResult[]
  assignments       Assignment[]
  submissions       Submission[]
  careerGuidance    CareerGuidance[]
  timeTables        TimeTable[]
  teacherSubjects   TeacherSubject[]
  substitutions     TeacherSubstitution[] @relation("TeacherSubstitute")
  classTeacher      ClassTeacher[]
  questionPapers    QuestionPaper[]

  @@map("teachers")
}

model Parent {
  id                Int            @id @default(autoincrement())
  userId            Int            @unique @map("user_id")
  studentId         Int            @map("student_id")
  relation          ParentRelation
  occupation        String?        @db.VarChar(100)
  annualIncome      Decimal?       @map("annual_income") @db.Decimal(12, 2)
  educationLevel    String?        @map("education_level") @db.VarChar(50)
  isPrimaryContact  Boolean        @default(false) @map("is_primary_contact")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Relations
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  student           Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("parents")
}

model Staff {
  id                Int              @id @default(autoincrement())
  userId            Int              @unique @map("user_id")
  institutionId     Int              @map("institution_id")
  employeeId        String           @unique @map("employee_id") @db.VarChar(50)
  staffType         StaffType        @map("staff_type")
  designation       String           @db.VarChar(100)
  department        String?          @db.VarChar(100)
  joinDate          DateTime?        @map("join_date") @db.Date
  salary            Decimal?         @db.Decimal(12, 2)
  employmentType    EmploymentType   @default(FULL_TIME) @map("employment_type")
  workingHours      String?          @map("working_hours") @db.VarChar(100)
  reportingManager  Int?             @map("reporting_manager")
  skills            String[]         // Array of skills
  qualifications    String?          @db.VarChar(300)
  experience        String?          @db.VarChar(300)
  emergencyContact  String?          @map("emergency_contact") @db.VarChar(15)
  address           String?
  status            StaffStatus      @default(ACTIVE)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution       Institution      @relation(fields: [institutionId], references: [id])
  attendance        StaffAttendance[]
  leaves            StaffLeave[]
  assignments       StaffAssignment[]

  @@map("staff")
}

