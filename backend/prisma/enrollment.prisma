// Enrollment and Class Management Models

model Enrollment {
  id                Int              @id @default(autoincrement())
  studentId         Int              @map("student_id")
  courseId          Int              @map("course_id")
  semesterId        Int              @map("semester_id")
  enrollmentDate    DateTime         @default(now()) @map("enrollment_date") @db.Date
  enrollmentStatus  EnrollmentStatus @default(ENROLLED) @map("enrollment_status")
  grade             String?          @db.VarChar(5)
  creditsEarned     Int              @default(0) @map("credits_earned")
  attendancePercentage Decimal?      @map("attendance_percentage") @db.Decimal(5, 2)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  student           Student          @relation(fields: [studentId], references: [id])
  course            Course           @relation(fields: [courseId], references: [id])
  semester          Semester         @relation(fields: [semesterId], references: [id])

  @@unique([studentId, courseId, semesterId], name: "unique_enrollment")
  @@map("enrollments")
}

model ClassSection {
  id                Int              @id @default(autoincrement())
  courseId          Int              @map("course_id")
  semesterId        Int              @map("semester_id")
  teacherId         Int              @map("teacher_id")
  sectionName       String           @map("section_name") @db.VarChar(10)
  maxCapacity       Int              @default(50) @map("max_capacity")
  currentEnrollment Int              @default(0) @map("current_enrollment")
  roomNumber        String?          @map("room_number") @db.VarChar(50)
  schedule          Json?            // {"Monday": "09:00-10:30", "Wednesday": "09:00-10:30"}
  status            ClassSectionStatus @default(ACTIVE)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  course            Course           @relation(fields: [courseId], references: [id])
  semester          Semester         @relation(fields: [semesterId], references: [id])
  teacher           Teacher          @relation(fields: [teacherId], references: [id])
  attendance        Attendance[]
  assignments       Assignment[]

  @@map("class_sections")
}

model Attendance {
  id          Int            @id @default(autoincrement())
  studentId   Int            @map("student_id")
  sectionId   Int            @map("section_id")
  date        DateTime       @db.Date
  status      AttendanceStatus
  remarks     String?
  markedBy    Int            @map("marked_by")
  markedAt    DateTime       @default(now()) @map("marked_at")

  // Relations
  student     Student        @relation(fields: [studentId], references: [id])
  section     ClassSection   @relation(fields: [sectionId], references: [id])
  marker      Teacher        @relation("AttendanceMarker", fields: [markedBy], references: [id])

  @@unique([studentId, sectionId, date], name: "unique_attendance")
  @@map("attendance")
}

// Enums
enum EnrollmentStatus {
  ENROLLED
  DROPPED
  COMPLETED
  FAILED
}

enum ClassSectionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}
